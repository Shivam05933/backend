<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mini Project</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="bg-zinc-900 min-h-screen w-full text-white py-10 px-10">
        <div class="flex justify-end">
            <a class="bg-red-400 rounded-md px-3 py-2" href="/logout">logout</a>
        </div>
        <h3 class="text-3xl ">hello, <%= user.name %>👋🏻</h3>
        <h5 class="mb-5">you can create a new post.</h5>

        <form action="/post" method="post">
            <textarea placeholder="what's on your mind ?" class=" p-2 w-1/3 resize-none bg-transparent outline-none border-2 border-zinc-800 rounded-md" name="content"></textarea>
            <input class="p-2 px-4 rounded-md mt-2 bg-blue-500 block outline-none" type="submit" value="Create New Post">
        </form>

        <div class="posts mt-10">
            <h3 class="text-zinc-400 text-2xl">Your Posts. </h3>
                <div class="postcontainer mt-5">
                    <div class="post w-1/3 p-3 rounded-md border-2 border-zinc-700 bg-zinc-800">
                        <h2 class="text-blue-500 mb-2">@somepost</h2>
                        <p class="text-sm tracking-tight">Lorem ipsum dolor sit amet consectetur adipisicing elit.
                            Labore omnis quis fugiat blanditiis cumque fugit eaque alias dolorum sint ea?</p>
                        
                        <div class="btns flex mt-2  gap-4">
                            <a class="text-blue-500" href="">Like</a>
                            <a class="text-zinc-500" href="">edit</a>
                        </div>
                    </div>
                </div>
            
        </div>
        
    </div>
</body>
</html>